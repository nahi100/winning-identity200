# ════════════════════════════════════════════════════════════════════
#  Environment variables — copy this file to .env and fill in values
#  Do NOT commit real values to git.
# ════════════════════════════════════════════════════════════════════

# PostgreSQL connection string (local install — see SETUP-GUIDE)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret for signing JWT auth tokens — use a long random string
JWT_SECRET=replace_with_a_long_random_secret_string

# Anthropic API key for the AI Coach (System 4)
# Get it at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Server port
PORT=8000

# For System 1 (Push) — connect FCM later
# FCM_SERVICE_ACCOUNT_JSON={...}

# ─── For System 3 (Coupons) when you connect payments ───
# STRIPE_SECRET_KEY=sk_live_xxx
